{
  "name": "mcp-mint",
  "version": "0.1.1",
  "description": "Test, validate, and scaffold MCP servers. ESLint + Lighthouse for the Model Context Protocol.",
  "type": "module",
  "keywords": ["mcp", "model-context-protocol", "testing", "linting", "security", "ai", "claude", "cursor"],
  "repository": {
    "type": "git",
    "url": "https://github.com/austindixson/mcp-mint.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "mcp-mint": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "chalk": "^5.4.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.1.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
